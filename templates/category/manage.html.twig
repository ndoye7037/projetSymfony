{% extends 'base.html.twig' %}

{% block body %}
    <main class="container">
        <h1 class="mb-4">Gestion des catégories</h1>

        <a href="{{ path('category_create') }}" class="btn btn-success mb-3">
            Ajouter une nouvelle catégorie
        </a>

        {% if category is empty %}
            <p>Aucune catégorie pour le moment </p>
        {% else %}
            <table class="table table-bordered">
                <thead>
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for c in category %}
                    <tr>
                        <td>{{ c.id }}</td>
                        <td>{{ c.name }}</td>
                        <td>{{ c.description|slice(0,50) }}...</td>
                        <td>
                            <a href="{{ path('read_category', {id: c.id}) }}" class="btn btn-info btn-sm">Voir</a>
                            <a href="{{ path('category_edit', {id: c.id}) }}" class="btn btn-warning btn-sm">Modifier</a>
                            <a href="{{ path('delete_category', {id: c.id}) }}" class="btn btn-danger btn-sm"
                               onclick="return confirm('Voulez-vous vraiment supprimer cette catégorie ?');">
                                Supprimer
                            </a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </main>
{% endblock %}
